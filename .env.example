# Your alt Roblox account's .ROBLOSECURITY cookie
# How to get it:
#   1. Log into roblox.com on Chrome with your ALT account
#   2. Press F12 → Application tab → Cookies → https://www.roblox.com
#   3. Find ".ROBLOSECURITY" → copy the Value
ROBLOSECURITY=your_cookie_here

# Discord webhook URL
# How to get it:
#   1. Go to your Discord server → channel settings → Integrations → Webhooks
#   2. New Webhook → Copy Webhook URL
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your/webhook

# Optional tuning
COOLDOWN_SECONDS=60
